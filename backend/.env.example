# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cravebit?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Mail Settings (Optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@cravebit.com
FROM_NAME=Cravebit

# Client URL (for CORS)
CLIENT_URL=https://cravebit-frontend.vercel.app

# Razorpay Integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
